generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────

enum MealPreference {
  VEG
  NONVEG
}

enum SelectionStatus {
  OPT_IN
  OPT_OUT
}

enum EmployeeRole {
  EMPLOYEE
  SUPERADMIN
}

// ─── Models ──────────────────────────────────────────────────────────

model Company {
  id        String           @id @default(cuid())
  name      String           // e.g. "FolksMeal"
  domain    String?
  createdAt DateTime         @default(now()) @map("created_at")

  addresses CompanyAddress[]
  employees Employee[]

  @@map("companies")
}

model CompanyAddress {
  id         String     @id @default(cuid())
  companyId  String     @map("company_id")
  city       String     // e.g. "Noida"
  state      String?    // e.g. "Uttar Pradesh"
  address    String?    // Full address
  cutoffTime String     @default("18:00") @map("cutoff_time")
  timezone   String     @default("Asia/Kolkata")
  createdAt  DateTime   @default(now()) @map("created_at")

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees  Employee[]
  menus      Menu[]

  @@map("company_addresses")
}

model Employee {
  id                String         @id @default(cuid())
  companyId         String         @map("company_id")
  addressId         String         @map("address_id")
  name              String
  employeeCode      String         @unique @map("employee_code")
  password          String
  defaultPreference MealPreference @default(VEG) @map("default_preference")
  role              EmployeeRole   @default(EMPLOYEE)
  createdAt         DateTime       @default(now()) @map("created_at")

  company           Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  address           CompanyAddress @relation(fields: [addressId], references: [id], onDelete: Cascade)
  selections        MealSelection[]

  @@map("employees")
}

model Menu {
  id           String         @id @default(cuid())
  addressId    String         @map("address_id")
  date         DateTime       @db.Date
  day          String?
  vegItem      String         @map("veg_item")
  nonvegItem   String?        @map("nonveg_item")
  sideBeverage String?        @map("side_beverage")
  notes        String?

  address      CompanyAddress @relation(fields: [addressId], references: [id], onDelete: Cascade)

  @@unique([addressId, date])
  @@map("menus")
}

model MealSelection {
  id         String          @id @default(cuid())
  employeeId String          @map("employee_id")
  date       DateTime        @db.Date
  status     SelectionStatus
  preference MealPreference? // null when opted out
  updatedAt  DateTime        @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@map("meal_selections")
}
