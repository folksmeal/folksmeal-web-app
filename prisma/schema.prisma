generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}



enum MealPreference {
  VEG
  NONVEG
}

enum UserRole {
  SUPERADMIN
  ADMIN
}

enum SelectionStatus {
  OPT_IN
  OPT_OUT
}



model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password      String
  plainPassword String?  @map("plain_password")
  role          UserRole @default(SUPERADMIN)
  companyId     String?  @map("company_id")
  createdAt     DateTime @default(now()) @map("created_at")

  company       Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@map("users")
}

model Company {
  id        String           @id @default(cuid())
  name      String
  domain    String?
  icon      String?
  createdAt DateTime         @default(now()) @map("created_at")

  addresses CompanyAddress[]
  adminFeatureConfig CompanyAdminFeatureConfig?
  employees Employee[]
  users     User[]

  @@map("companies")
}

model CompanyAdminFeatureConfig {
  id                        String   @id @default(cuid())
  companyId                 String   @unique @map("company_id")
  employeeManagementEnabled Boolean  @default(true) @map("employee_management_enabled")
  menuEnabled               Boolean  @default(true) @map("menu_enabled")
  reviewsEnabled            Boolean  @default(true) @map("reviews_enabled")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_admin_feature_configs")
}

model CompanyAddress {
  id         String     @id @default(cuid())
  companyId  String     @map("company_id")
  city       String
  state      String?
  address    String?
  cutoffTime String     @default("18:00") @map("cutoff_time")
  timezone   String     @default("Asia/Kolkata")
  workingDays Int[]     @default([1, 2, 3, 4, 5]) @map("working_days")
  createdAt  DateTime   @default(now()) @map("created_at")

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees  Employee[]
  menus      Menu[]

  @@index([companyId])
  @@map("company_addresses")
}

model Employee {
  id                String         @id @default(cuid())
  companyId         String         @map("company_id")
  addressId         String         @map("address_id")
  name              String
  employeeCode      String         @unique @map("employee_code")
  email             String?        @unique
  password          String
  plainPassword     String?        @map("plain_password")
  defaultPreference MealPreference @default(VEG) @map("default_preference")
  createdAt         DateTime       @default(now()) @map("created_at")

  company           Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  address           CompanyAddress @relation(fields: [addressId], references: [id], onDelete: Cascade)
  selections        MealSelection[]
  ratings           MealRating[]

  @@index([companyId])
  @@index([addressId])
  @@map("employees")
}

model Menu {
  id           String         @id @default(cuid())
  addressId    String         @map("address_id")
  date         DateTime       @db.Date
  day          String?
  vegItem      String         @map("veg_item")
  nonvegItem   String?        @map("nonveg_item")
  sideBeverage String?        @map("side_beverage")
  notes        String?

  address      CompanyAddress @relation(fields: [addressId], references: [id], onDelete: Cascade)

  @@index([addressId])
  @@index([date])
  @@unique([addressId, date])
  @@map("menus")
}

model MealSelection {
  id         String          @id @default(cuid())
  employeeId String          @map("employee_id")
  date       DateTime        @db.Date
  status     SelectionStatus
  preference MealPreference?
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([employeeId])
  @@unique([employeeId, date])
  @@map("meal_selections")
}

model MealRating {
  id         String   @id @default(cuid())
  employeeId String   @map("employee_id")
  date       DateTime @db.Date
  rating     Int
  comment    String?
  createdAt  DateTime @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([employeeId])
  @@unique([employeeId, date])
  @@map("meal_ratings")
}
