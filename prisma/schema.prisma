generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}



enum MealPreference {
  VEG
  NONVEG
}

enum UserRole {
  SUPERADMIN
  ADMIN
}

enum SelectionStatus {
  OPT_IN
  OPT_OUT
}



model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password      String
  plainPassword String?  @map("plain_password")
  role          UserRole @default(SUPERADMIN)
  companyId     String?  @map("company_id")
  createdAt     DateTime @default(now()) @map("created_at")

  company       Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@map("users")
}

model Company {
  id        String           @id @default(cuid())
  name      String
  domain    String?
  icon      String?
  createdAt DateTime         @default(now()) @map("created_at")

  addresses CompanyAddress[]
  adminFeatureConfig CompanyAdminFeatureConfig?
  employees Employee[]
  users     User[]

  @@map("companies")
}

model CompanyAdminFeatureConfig {
  id                        String   @id @default(cuid())
  companyId                 String   @unique @map("company_id")
  employeeManagementEnabled Boolean  @default(true) @map("employee_management_enabled")
  menuEnabled               Boolean  @default(true) @map("menu_enabled")
  reviewsEnabled            Boolean  @default(true) @map("reviews_enabled")
  addonsEnabled             Boolean  @default(false) @map("addons_enabled")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_admin_feature_configs")
}

model CompanyAddress {
  id         String     @id @default(cuid())
  companyId  String     @map("company_id")
  city       String
  state      String?
  address    String?
  cutoffTime String     @default("18:00") @map("cutoff_time")
  timezone   String     @default("Asia/Kolkata")
  workingDays Int[]     @default([1, 2, 3, 4, 5]) @map("working_days")
  createdAt  DateTime   @default(now()) @map("created_at")

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees  Employee[]
  menus      Menu[]

  @@index([companyId])
  @@map("company_addresses")
}

model Employee {
  id                String         @id @default(cuid())
  companyId         String         @map("company_id")
  addressId         String         @map("address_id")
  name              String
  employeeCode      String         @unique @map("employee_code")
  email             String?        @unique
  password          String
  plainPassword     String?        @map("plain_password")
  defaultPreference MealPreference @default(VEG) @map("default_preference")
  createdAt         DateTime       @default(now()) @map("created_at")

  company           Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  address           CompanyAddress @relation(fields: [addressId], references: [id], onDelete: Cascade)
  selections        MealSelection[]
  ratings           MealRating[]

  @@index([companyId])
  @@index([addressId])
  @@map("employees")
}

model MenuItem {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  vegMenus    Menu[]   @relation("VegItem")
  nonvegMenus Menu[]   @relation("NonvegItem")

  @@map("menu_items")
}

model Menu {
  id           String         @id @default(cuid())
  addressId    String         @map("address_id")
  date         DateTime       @db.Date
  day          String?
  vegItem      String         @map("veg_item")
  vegItemId    String?        @map("veg_item_id")
  nonvegItem   String?        @map("nonveg_item")
  nonvegItemId String?        @map("nonveg_item_id")
  sideBeverage String?        @map("side_beverage")
  notes        String?

  address      CompanyAddress @relation(fields: [addressId], references: [id], onDelete: Cascade)
  vegItemRef    MenuItem?      @relation("VegItem", fields: [vegItemId], references: [id], onDelete: SetNull)
  nonvegItemRef MenuItem?      @relation("NonvegItem", fields: [nonvegItemId], references: [id], onDelete: SetNull)

  @@index([addressId])
  @@index([date])
  @@index([vegItemId])
  @@index([nonvegItemId])
  @@unique([addressId, date])
  @@map("menus")
}

model MealSelection {
  id         String               @id @default(cuid())
  employeeId String               @map("employee_id")
  date       DateTime             @db.Date
  status     SelectionStatus
  preference MealPreference?
  createdAt  DateTime             @default(now()) @map("created_at")
  updatedAt  DateTime             @updatedAt @map("updated_at")

  employee   Employee             @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  addons     MealSelectionAddon[]

  @@index([date])
  @@index([employeeId])
  @@unique([employeeId, date])
  @@map("meal_selections")
}

enum AddonType {
  MAIN_REPEAT
  PROTEIN_SIDE
  BEVERAGE
  SIDE_DESSERT
  BREAD_ADDITION
}

model Addon {
  id             String               @id @default(cuid())
  name           String               @unique
  unitPrice      Float                @map("unit_price")
  maxQty         Int                  @map("max_qty")
  isRepeatable   Boolean              @default(false) @map("is_repeatable")
  isLinkedToMenu Boolean              @default(false) @map("is_linked_to_menu")
  type           AddonType
  active         Boolean              @default(true)
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  selections     MealSelectionAddon[]

  @@map("addons")
}

model MealSelectionAddon {
  id               String        @id @default(cuid())
  mealSelectionId  String        @map("meal_selection_id")
  addonId          String        @map("addon_id")
  quantity         Int
  priceAtSelection Float         @map("price_at_selection")

  mealSelection    MealSelection @relation(fields: [mealSelectionId], references: [id], onDelete: Cascade)
  addon            Addon         @relation(fields: [addonId], references: [id], onDelete: Restrict)

  @@index([mealSelectionId])
  @@index([addonId])
  @@unique([mealSelectionId, addonId])
  @@map("meal_selection_addons")
}

model MealRating {
  id         String   @id @default(cuid())
  employeeId String   @map("employee_id")
  date       DateTime @db.Date
  rating     Int
  comment    String?
  createdAt  DateTime @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([employeeId])
  @@unique([employeeId, date])
  @@map("meal_ratings")
}
